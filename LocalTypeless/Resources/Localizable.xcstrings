      }
    },
    "Dev builds change identity on every rebuild, which can orphan your previous grants. If permissions stay denied after enabling them, reset and grant again, then quit & relaunch." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Dev builds change identity on every rebuild, which can orphan your previous grants. If permissions stay denied after enabling them, reset and grant again, then quit & relaunch." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开发版应用每次重新构建都会改变身份，可能使之前授予的权限失效。若开启权限后仍显示被拒，请先重置再重新授予，然后退出并重新启动。" } }
